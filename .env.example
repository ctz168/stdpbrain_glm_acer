# 类人脑双系统全闭环AI架构 - 环境变量配置示例
# Human-Like Brain Dual-System Full-Loop AI Architecture - Environment Config

# Telegram Bot Token（必填）
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# 模型路径
MODEL_PATH=/app/models/Qwen3.5-0.8B

# 日志级别
LOG_LEVEL=INFO

# 刷新频率
REFRESH_RATE=100

# STDP学习参数
STDP_ALPHA=0.01
STDP_BETA=0.008

# 海马体配置
HIPPOCAMPUS_MEMORY_CAPACITY=10000
HIPPOCAMPUS_MAX_MEMORY_MB=2
